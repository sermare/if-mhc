# Whitelist-style .gitignore: everything is ignored by default (huge generated
# artifacts live under outputs/, RFdiffusion/, ProteinMPNN/, etc.), and only the
# specific paths below are tracked.
*
!.gitignore
!README.md
!MAIN_CLAIMS.md
!ANALYSIS_WALKTHROUGH.md

# analysis notebooks (flat directory; do not sweep in vendored
# RFdiffusion/ProteinMPNN example notebooks)
!notebooks/
!notebooks/*.ipynb

# scripts (flat directory of .py files; exclude __pycache__)
!py/
!py/*.py

# RFdiffusion campaign job drivers (flat directory of .sh/.tsv)
!jobs/
!jobs/*

# paper: LaTeX source + compiled PDF + required style files
# (excludes paper.aux/paper.log build artifacts and the AAAI instructions doc)
!paper/
!paper/paper.tex
!paper/paper.pdf
!paper/aaai.sty
!paper/aaai.bst
!paper/fixbib.sty
# ISCB abstract-book submission: 250-word text abstract + single-page print-ready PDF
!paper/iscb_onepager.tex
!paper/iscb_onepager.pdf
!paper/iscb_abstract_250w.txt

# figures (final renders + the scripts that build them)
!figures/
!figures/**

# inputs: only the 6AM* crystal structures and RFdiffusion spec files used
# throughout this analysis — not the larger unrelated datasets under inputs/
!inputs/
!inputs/focus_6am/
!inputs/focus_6am/**

# outputs: the ~50GB working directory is NOT tracked. The one exception is a
# curated zip of just the final designed backbones used in the paper,
# regrouped by conditioning cell instead of by launch campaign (see
# outputs/README.md for what this is and how to regenerate it).
!outputs/
!outputs/README.md
!outputs/paper_designs_by_condition.zip
!outputs/allcond150_designs_by_condition.zip
!outputs/condition_manifest.csv

# Hard guard: NEVER track uncompressed/raw structure files, even if the .zip is
# unpacked in place or a broader whitelist is added later. Only the curated .zip
# and the CSV manifest belong in git — not the loose backbones themselves.
outputs/**/*.pdb
outputs/**/*.cif
outputs/**/*.trb
outputs/**/*.npz
outputs/condition_*/
outputs/allcond150/
outputs/null_extra300/
outputs/rfd_null/

# Exception to the hard guard: the extended 300K/50ns native MD calibration run
# (2ns equil + 50ns production, same protocol as the 370K extended run). Only
# the water-stripped 1000-frame trajectory + topology (needed to redo our own
# Ca-RMSD/occupancy scoring) and Tamarind's precomputed per-frame analysis
# tables (RMSD/RMSF/Rg/cross-correlation, csv+parquet) are tracked -- not the
# solvated traj_equil.xtc/traj_prod.xtc, checkpoint, prmtop/inpcrd, or PNGs.
!outputs/tamarind/
!outputs/tamarind/results/
!outputs/tamarind/results/ifmhc_6AM5_md_300K_ext/
!outputs/tamarind/results/ifmhc_6AM5_md_300K_ext/topology_no_water.pdb
!outputs/tamarind/results/ifmhc_6AM5_md_300K_ext/traj_prod_no_water_seg1.xtc
!outputs/tamarind/results/ifmhc_6AM5_md_300K_ext/analysis/
!outputs/tamarind/results/ifmhc_6AM5_md_300K_ext/analysis/*.csv
!outputs/tamarind/results/ifmhc_6AM5_md_300K_ext/analysis/*.parquet
!outputs/tamarind/results/ifmhc_6AMU_md_300K_ext/
!outputs/tamarind/results/ifmhc_6AMU_md_300K_ext/topology_no_water.pdb
!outputs/tamarind/results/ifmhc_6AMU_md_300K_ext/traj_prod_no_water_seg1.xtc
!outputs/tamarind/results/ifmhc_6AMU_md_300K_ext/analysis/
!outputs/tamarind/results/ifmhc_6AMU_md_300K_ext/analysis/*.csv
!outputs/tamarind/results/ifmhc_6AMU_md_300K_ext/analysis/*.parquet

# Extended 370K/50ns native MD calibration run (Tamarind job IDs: lbv69=6AM5,
# p1yv2=6AMU) -- same curation as the 300K_ext run above.
!outputs/tamarind/results/lbv69/
!outputs/tamarind/results/lbv69/topology_no_water.pdb
!outputs/tamarind/results/lbv69/traj_prod_no_water_seg1.xtc
!outputs/tamarind/results/lbv69/analysis/
!outputs/tamarind/results/lbv69/analysis/*.csv
!outputs/tamarind/results/lbv69/analysis/*.parquet
!outputs/tamarind/results/p1yv2/
!outputs/tamarind/results/p1yv2/topology_no_water.pdb
!outputs/tamarind/results/p1yv2/traj_prod_no_water_seg1.xtc
!outputs/tamarind/results/p1yv2/analysis/
!outputs/tamarind/results/p1yv2/analysis/*.csv
!outputs/tamarind/results/p1yv2/analysis/*.parquet

# 310K/50ns native MD calibration run (2ns equil + 50ns production, ff19SB,
# same protocol as 300K_ext/370K above) -- same curation.
!outputs/tamarind/results/ifmhc_6AM5_md_310K/
!outputs/tamarind/results/ifmhc_6AM5_md_310K/topology_no_water.pdb
!outputs/tamarind/results/ifmhc_6AM5_md_310K/traj_prod_no_water_seg1.xtc
!outputs/tamarind/results/ifmhc_6AM5_md_310K/analysis/
!outputs/tamarind/results/ifmhc_6AM5_md_310K/analysis/*.csv
!outputs/tamarind/results/ifmhc_6AM5_md_310K/analysis/*.parquet
!outputs/tamarind/results/ifmhc_6AMU_md_310K/
!outputs/tamarind/results/ifmhc_6AMU_md_310K/topology_no_water.pdb
!outputs/tamarind/results/ifmhc_6AMU_md_310K/traj_prod_no_water_seg1.xtc
!outputs/tamarind/results/ifmhc_6AMU_md_310K/analysis/
!outputs/tamarind/results/ifmhc_6AMU_md_310K/analysis/*.csv
!outputs/tamarind/results/ifmhc_6AMU_md_310K/analysis/*.parquet

# corpus scoring table + this analysis's outputs -- small CSVs, not raw
# structures, but needed to reproduce the 300K_ext vs 370K comparison.
!outputs/denovo_scores/
!outputs/denovo_scores/per_design.csv
!outputs/native_md_rmsd/
!outputs/native_md_rmsd/md_300K_extended_per_frame.csv
!outputs/native_md_rmsd/denovo_classified_300Kext_vs_370K.csv
!outputs/native_md_rmsd/md_310K_6AM5_per_frame.csv
!outputs/native_md_rmsd/md_310K_6AMU_per_frame.csv
